@model List<ClaimPortal.ViewModels.ClaimViewModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mt-3 mb-3">Submitted Claims</h2>

<form method="get" class="row mb-4">
    <div class="col-md-3">
        <input name="claimNumber" class="form-control" placeholder="Search by Claim Number" />
    </div>

    <div class="col-md-3">
        <input name="status" class="form-control" placeholder="Search by Status" />
    </div>

    <div class="col-md-2">
        <button class="btn btn-primary w-100">Search</button>
    </div>
</form>

<table class="table table-bordered table-striped shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Claim #</th>
            <th>Patient</th>
            <th>Date</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Remarks</th>
            <th style="width:150px;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.ClaimNumber</td>
                <td>@c.PatientName</td>
                <td>@c.SubmissionDate.ToShortDateString()</td>
                <td>@c.ClaimAmount</td>
                <td>@c.ProcessingStatus</td>
                <td>@c.Remarks</td>

                <td>
                    <a class="btn btn-sm btn-warning" href="/Claim/Edit/@c.ClaimId">Edit</a>
                    <a class="btn btn-sm btn-info" href="/History/Index?claimNumber=@c.ClaimNumber">History</a>                </td>
            </tr>
        }
    </tbody>
</table>